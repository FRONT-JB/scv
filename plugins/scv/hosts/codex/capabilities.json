{
  "schemaVersion": 1,
  "host": "codex",
  "minimumVersion": "0.144.5",
  "manifest": ".codex-plugin/plugin.json",
  "projectSkillRoot": ".agents/skills",
  "supportsDirectorySymlinks": true,
  "backend": {
    "executable": "codex",
    "subcommands": [
      "exec",
      "exec review"
    ],
    "requiredFlags": [
      "--ephemeral",
      "--ignore-user-config",
      "--ignore-rules",
      "--strict-config",
      "--output-schema",
      "--json",
      "--sandbox",
      "--cd"
    ],
    "forbiddenFlags": [
      "--add-dir",
      "--dangerously-bypass-approvals-and-sandbox",
      "--dangerously-bypass-hook-trust"
    ]
  },
  "sandbox": {
    "requiredModes": [
      "read-only",
      "workspace-write"
    ],
    "toolNetworkAccess": false,
    "failClosed": true
  }
}
