{
  "schemaVersion": 1,
  "host": "claude",
  "minimumVersion": "2.1.203",
  "manifest": ".claude-plugin/plugin.json",
  "projectSkillRoot": ".claude/skills",
  "supportsDirectorySymlinks": true,
  "backend": {
    "executable": "claude",
    "requiredFlags": [
      "--bare",
      "--plugin-dir",
      "--print",
      "--output-format",
      "--json-schema",
      "--no-session-persistence",
      "--permission-mode",
      "--tools",
      "--disallowedTools",
      "--settings"
    ],
    "forbiddenFlags": [
      "--dangerously-skip-permissions",
      "--worktree",
      "--background",
      "--chrome"
    ]
  },
  "sandbox": {
    "enabled": true,
    "failIfUnavailable": true,
    "allowUnsandboxedCommands": false,
    "toolNetworkAccess": false,
    "failClosed": true
  }
}
