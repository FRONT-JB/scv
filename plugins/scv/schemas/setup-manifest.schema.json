{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:scv:schema:setup-manifest:1.0.0",
  "title": "SCV local setup manifest",
  "type": "object",
  "required": ["schemaVersion", "installationId", "pluginVersion", "mode", "sourceBundleDigest", "installedBundleDigest", "createdAt", "updatedAt", "managedEntries"],
  "properties": {
    "schemaVersion": { "const": "1.0.0" },
    "installationId": { "$ref": "#/$defs/uuid" },
    "pluginVersion": { "$ref": "#/$defs/semver" },
    "mode": { "enum": ["linked", "installed", "cutover_pending"] },
    "sourceBundleDigest": { "$ref": "#/$defs/digest" },
    "installedBundleDigest": { "$ref": "#/$defs/digest" },
    "createdAt": { "$ref": "#/$defs/utcDateTime" },
    "updatedAt": { "$ref": "#/$defs/utcDateTime" },
    "managedEntries": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/managedEntry" }
    }
  },
  "$defs": {
    "uuid": { "type": "string", "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-4[0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$" },
    "semver": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+(?:[-+][0-9A-Za-z.-]+)?$" },
    "digest": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
    "utcDateTime": { "type": "string", "format": "date-time", "pattern": "^[0-9]{4}-(?:0[1-9]|1[0-2])-(?:0[1-9]|[12][0-9]|3[01])T(?:[01][0-9]|2[0-3]):[0-5][0-9]:[0-5][0-9](?:\\.[0-9]{1,9})?Z$" },
    "directoryPath": {
      "oneOf": [
        {
          "enum": [
            ".scv",
            ".scv/config",
            ".scv/tasks",
            ".scv/runtime",
            ".scv/runtime/locks",
            ".scv/runtime/cache",
            ".scv/runtime/tmp",
            ".agents",
            ".agents/skills",
            ".claude",
            ".claude/skills"
          ]
        },
        {
          "type": "string",
          "maxLength": 1024,
          "pattern": "^\\.scv/plugin(?:/[A-Za-z0-9._@+-]+)*$",
          "not": { "pattern": "(?:^|/)\\.\\.?(?:/|$)|//|\\\\" }
        },
        {
          "type": "string",
          "maxLength": 1024,
          "pattern": "^\\.scv/docs(?:/[A-Za-z0-9._@+-]+)*$",
          "not": { "pattern": "(?:^|/)\\.\\.?(?:/|$)|//|\\\\" }
        }
      ]
    },
    "trackedFilePath": {
      "oneOf": [
        {
          "enum": [
            ".scv/config/project.json",
            ".scv/config/workflow-policy.json",
            ".scv/config/model-policy.json",
            ".scv/.gitignore"
          ]
        },
        {
          "type": "string",
          "maxLength": 1024,
          "pattern": "^\\.scv/plugin/[A-Za-z0-9._@+-]+(?:/[A-Za-z0-9._@+-]+)*$",
          "not": { "pattern": "(?:^|/)\\.\\.?(?:/|$)|//|\\\\" }
        },
        {
          "type": "string",
          "maxLength": 1024,
          "pattern": "^\\.scv/docs/[A-Za-z0-9._@+-]+(?:/[A-Za-z0-9._@+-]+)*$",
          "not": { "pattern": "(?:^|/)\\.\\.?(?:/|$)|//|\\\\" }
        }
      ]
    },
    "localFilePath": {
      "enum": [
        ".scv/config/link-manifest.json",
        ".scv/config/setup-manifest.json"
      ]
    },
    "linkPath": {
      "enum": [
        ".agents/skills/setup",
        ".agents/skills/scv-1-plan",
        ".claude/skills/setup",
        ".claude/skills/scv-1-plan"
      ]
    },
    "managedPath": {
      "anyOf": [
        { "$ref": "#/$defs/directoryPath" },
        { "$ref": "#/$defs/trackedFilePath" },
        { "$ref": "#/$defs/localFilePath" },
        { "$ref": "#/$defs/linkPath" }
      ]
    },
    "managedEntry": {
      "type": "object",
      "required": ["path", "kind", "digest", "targetPath", "ownership", "tracked"],
      "properties": {
        "path": { "$ref": "#/$defs/managedPath" },
        "kind": { "enum": ["file", "directory", "symlink"] },
        "digest": { "oneOf": [{ "type": "null" }, { "$ref": "#/$defs/digest" }] },
        "targetPath": {
          "oneOf": [
            { "type": "null" },
            { "const": "../../.scv/plugin/skills/setup" },
            { "const": "../../.scv/plugin/skills/scv-1-plan" }
          ]
        },
        "ownership": { "enum": ["managed", "preserved"] },
        "tracked": { "type": "boolean" }
      },
      "allOf": [
        {
          "if": { "properties": { "kind": { "const": "directory" } }, "required": ["kind"] },
          "then": {
            "properties": {
              "path": { "$ref": "#/$defs/directoryPath" },
              "digest": { "oneOf": [{ "type": "null" }, { "$ref": "#/$defs/digest" }] },
              "targetPath": { "type": "null" },
              "tracked": { "const": false }
            }
          }
        },
        {
          "if": { "properties": { "kind": { "const": "file" } }, "required": ["kind"] },
          "then": {
            "properties": {
              "digest": { "$ref": "#/$defs/digest" },
              "targetPath": { "type": "null" }
            },
            "oneOf": [
              {
                "properties": {
                  "path": { "$ref": "#/$defs/trackedFilePath" },
                  "tracked": { "const": true }
                },
                "required": ["path", "tracked"]
              },
              {
                "properties": {
                  "path": { "$ref": "#/$defs/localFilePath" },
                  "tracked": { "const": false }
                },
                "required": ["path", "tracked"]
              }
            ]
          }
        },
        {
          "if": { "properties": { "kind": { "const": "symlink" } }, "required": ["kind"] },
          "then": {
            "properties": {
              "digest": { "$ref": "#/$defs/digest" },
              "ownership": { "const": "managed" },
              "tracked": { "const": true }
            },
            "oneOf": [
              { "$ref": "#/$defs/codexSetupLink" },
              { "$ref": "#/$defs/codexPlanLink" },
              { "$ref": "#/$defs/claudeSetupLink" },
              { "$ref": "#/$defs/claudePlanLink" }
            ]
          }
        }
      ],
      "additionalProperties": false
    },
    "codexSetupLink": {
      "required": ["path", "targetPath"],
      "properties": {
        "path": { "const": ".agents/skills/setup" },
        "targetPath": { "const": "../../.scv/plugin/skills/setup" }
      }
    },
    "codexPlanLink": {
      "required": ["path", "targetPath"],
      "properties": {
        "path": { "const": ".agents/skills/scv-1-plan" },
        "targetPath": { "const": "../../.scv/plugin/skills/scv-1-plan" }
      }
    },
    "claudeSetupLink": {
      "required": ["path", "targetPath"],
      "properties": {
        "path": { "const": ".claude/skills/setup" },
        "targetPath": { "const": "../../.scv/plugin/skills/setup" }
      }
    },
    "claudePlanLink": {
      "required": ["path", "targetPath"],
      "properties": {
        "path": { "const": ".claude/skills/scv-1-plan" },
        "targetPath": { "const": "../../.scv/plugin/skills/scv-1-plan" }
      }
    }
  },
  "additionalProperties": false
}
