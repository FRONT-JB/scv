{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:scv:schema:workflow-policy:1.0.0",
  "title": "SCV workflow policy",
  "type": "object",
  "required": ["schemaVersion", "transitions", "blockedResume", "planning", "attempts", "findings", "executors", "retention"],
  "properties": {
    "schemaVersion": { "const": "1.0.0" },
    "transitions": {
      "type": "object",
      "required": ["PLANNING", "AWAITING_APPROVAL", "PLAN_READY", "EXECUTING", "VERIFYING", "HANDOFF_READY", "BLOCKED", "READY", "ABANDONED"],
      "properties": {
        "PLANNING": { "const": ["AWAITING_APPROVAL", "BLOCKED", "ABANDONED"] },
        "AWAITING_APPROVAL": { "const": ["PLANNING", "PLAN_READY", "BLOCKED", "ABANDONED"] },
        "PLAN_READY": { "const": ["EXECUTING", "PLANNING", "BLOCKED", "ABANDONED"] },
        "EXECUTING": { "const": ["VERIFYING", "PLANNING", "BLOCKED", "ABANDONED"] },
        "VERIFYING": { "const": ["EXECUTING", "PLANNING", "HANDOFF_READY", "BLOCKED", "ABANDONED"] },
        "HANDOFF_READY": { "const": ["EXECUTING", "PLANNING", "READY", "BLOCKED", "ABANDONED"] },
        "BLOCKED": { "const": ["PLANNING", "AWAITING_APPROVAL", "PLAN_READY", "EXECUTING", "VERIFYING", "HANDOFF_READY", "ABANDONED"] },
        "READY": { "const": [] },
        "ABANDONED": { "const": [] }
      },
      "additionalProperties": false
    },
    "blockedResume": {
      "type": "object",
      "required": ["sameStateReasons", "sameStateResumeTo", "workspaceDrift", "abandon"],
      "properties": {
        "sameStateReasons": {
          "const": ["BACKEND_UNAVAILABLE", "HOST_INCOMPATIBLE", "SANDBOX_UNAVAILABLE", "POLICY_DENIED", "CREDENTIAL_UNAVAILABLE", "BINDING_MISMATCH", "EVIDENCE_CORRUPT", "STATE_CORRUPT"]
        },
        "sameStateResumeTo": {"const": "blockedFrom"},
        "workspaceDrift": {
          "type": "object",
          "required": ["reasonCode", "exactRestoreResumeTo", "rebaselineResumeTo"],
          "properties": {
            "reasonCode": {"const": "WORKSPACE_DRIFT"},
            "exactRestoreResumeTo": {"const": "blockedFrom"},
            "rebaselineResumeTo": {"const": "PLANNING"}
          },
          "additionalProperties": false
        },
        "abandon": {
          "type": "object",
          "required": ["targetState", "requiresUserConfirmation", "usesResumeTo"],
          "properties": {
            "targetState": {"const": "ABANDONED"},
            "requiresUserConfirmation": {"const": true},
            "usesResumeTo": {"const": false}
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "planning": {
      "type": "object",
      "required": ["stages", "requireExplicitAssumptionAcceptance"],
      "properties": {
        "stages": {
          "type": "array",
          "prefixItems": [
            { "const": "CONTEXT" },
            { "const": "DIALOGUE" },
            { "const": "OPTIONS" },
            { "const": "DESIGN_REVIEW" },
            { "const": "PLAN_REVIEW" }
          ],
          "minItems": 5,
          "maxItems": 5
        },
        "requireExplicitAssumptionAcceptance": { "const": true }
      },
      "additionalProperties": false
    },
    "attempts": {
      "type": "object",
      "required": ["minimum", "default", "maximum", "terminationReasons"],
      "properties": {
        "minimum": { "const": 1 },
        "default": { "type": "integer", "minimum": 1, "maximum": 3 },
        "maximum": { "const": 3 },
        "terminationReasons": {
          "const": ["budget_exhausted", "stalled", "oscillating", "verifier_disagreement"]
        }
      },
      "additionalProperties": false
    },
    "findings": {
      "type": "object",
      "required": ["severityDisposition", "nonWaivableClasses"],
      "properties": {
        "severityDisposition": {
          "type": "object",
          "required": ["critical", "high", "medium", "low"],
          "properties": {
            "critical": { "const": "must_fix" },
            "high": { "const": "must_fix" },
            "medium": { "enum": ["must_fix", "waivable"] },
            "low": { "const": "advisory" }
          },
          "additionalProperties": false
        },
        "nonWaivableClasses": {
          "const": ["security_boundary", "data_loss", "scope_violation", "sandbox_failure", "acceptance_failure"]
        }
      },
      "additionalProperties": false
    },
    "executors": {
      "type": "object",
      "required": ["allowed", "reviewBackend"],
      "properties": {
        "allowed": { "const": ["host", "kernel", "backend"] },
        "reviewBackend": { "const": "codex" }
      },
      "additionalProperties": false
    },
    "retention": {
      "type": "object",
      "required": ["automaticDeletion", "terminalTaskDaysBeforePrune", "runtimeCleanupDays"],
      "properties": {
        "automaticDeletion": { "const": false },
        "terminalTaskDaysBeforePrune": { "type": "integer", "minimum": 90 },
        "runtimeCleanupDays": { "type": "integer", "minimum": 7 }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
