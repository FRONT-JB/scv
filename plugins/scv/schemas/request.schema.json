{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:scv:schema:request:1.0.0",
  "title": "SCV normalized request",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "taskId", "revision", "receivedAt", "language", "mode", "summary", "goals", "nonGoals", "constraints", "scopeChanges", "sourceDigest"],
  "properties": {
    "schemaVersion": {"const": "1.0.0"},
    "taskId": {"type": "string", "pattern": "^T-[0-9]{8}T[0-9]{6}Z-[a-z2-7]{26}$"},
    "revision": {"type": "integer", "minimum": 1},
    "receivedAt": {"type": "string", "format": "date-time", "pattern": "^[0-9]{4}-(?:0[1-9]|1[0-2])-(?:0[1-9]|[12][0-9]|3[01])T(?:[01][0-9]|2[0-3]):[0-5][0-9]:[0-5][0-9](?:\\.[0-9]{1,9})?Z$"},
    "language": {"enum": ["ko", "en"]},
    "mode": {"enum": ["PLAN_ONLY", "FULL"]},
    "summary": {"type": "string", "minLength": 1},
    "goals": {"$ref": "#/$defs/textList"},
    "nonGoals": {"type": "array", "items": {"type": "string", "minLength": 1}, "uniqueItems": true},
    "constraints": {"type": "array", "items": {"type": "string", "minLength": 1}, "uniqueItems": true},
    "scopeChanges": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["revision", "receivedAt", "summary"],
        "properties": {
          "revision": {"type": "integer", "minimum": 2},
          "receivedAt": {"type": "string", "format": "date-time", "pattern": "^[0-9]{4}-(?:0[1-9]|1[0-2])-(?:0[1-9]|[12][0-9]|3[01])T(?:[01][0-9]|2[0-3]):[0-5][0-9]:[0-5][0-9](?:\\.[0-9]{1,9})?Z$"},
          "summary": {"type": "string", "minLength": 1}
        }
      }
    },
    "sourceDigest": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"}
  },
  "$defs": {
    "textList": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}, "uniqueItems": true}
  }
}
