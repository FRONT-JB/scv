{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:scv:schema:plan:1.0.0",
  "title": "SCV execution plan",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "taskId", "revision", "requestRevision", "dialogueRevision", "createdAt", "summary", "steps", "handoffCriteria"],
  "properties": {
    "schemaVersion": {"const": "1.0.0"},
    "taskId": {"type": "string", "pattern": "^T-[0-9]{8}T[0-9]{6}Z-[a-z2-7]{26}$"},
    "revision": {"type": "integer", "minimum": 1},
    "requestRevision": {"type": "integer", "minimum": 1},
    "dialogueRevision": {"type": "integer", "minimum": 1},
    "createdAt": {"type": "string", "format": "date-time", "pattern": "^[0-9]{4}-(?:0[1-9]|1[0-2])-(?:0[1-9]|[12][0-9]|3[01])T(?:[01][0-9]|2[0-3]):[0-5][0-9]:[0-5][0-9](?:\\.[0-9]{1,9})?Z$"},
    "summary": {"type": "string", "minLength": 1},
    "steps": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"$ref": "#/$defs/step"}},
    "handoffCriteria": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}, "uniqueItems": true}
  },
  "$defs": {
    "stepId": {"type": "string", "pattern": "^step-[0-9]{3}$"},
    "operationId": {"type": "string", "pattern": "^[a-z][a-z0-9]*(?:-[a-z0-9]+)*$"},
    "relativePath": {"type": "string", "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$))(?!.*//)(?!.*\\\\)(?:\\.|[A-Za-z0-9._-]+(?:/[A-Za-z0-9._-]+)*)$"},
    "safeWorkspacePath": {
      "allOf": [
        {"$ref": "#/$defs/relativePath"},
        {"not": {"pattern": "^(?:\\.[gG][iI][tT](?:/|$)|\\.[sS][cC][vV]/(?:[pP][lL][uU][gG][iI][nN]|[tT][aA][sS][kK][sS]|[rR][uU][nN][tT][iI][mM][eE])(?:/|$)|\\.[sS][cC][vV]/[cC][oO][nN][fF][iI][gG]/(?:[lL][iI][nN][kK]-[mM][aA][nN][iI][fF][eE][sS][tT]|[sS][eE][tT][uU][pP]-[mM][aA][nN][iI][fF][eE][sS][tT])\\.[jJ][sS][oO][nN]$|\\.[sS][cC][vV]/\\.[gG][iI][tT][iI][gG][nN][oO][rR][eE]$|\\.[aA][gG][eE][nN][tT][sS]/[sS][kK][iI][lL][lL][sS](?:/|$)|\\.[cC][lL][aA][uU][dD][eE]/[sS][kK][iI][lL][lL][sS](?:/|$))"}}
      ]
    },
    "step": {
      "type": "object", "additionalProperties": false,
      "required": ["id", "title", "objective", "dependsOn", "operationId", "allowedPathRoots", "maxAttempts", "acceptance"],
      "properties": {
        "id": {"$ref": "#/$defs/stepId"},
        "title": {"type": "string", "minLength": 1},
        "objective": {"type": "string", "minLength": 1},
        "dependsOn": {"type": "array", "items": {"$ref": "#/$defs/stepId"}, "uniqueItems": true},
        "operationId": {"$ref": "#/$defs/operationId"},
        "allowedPathRoots": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/safeWorkspacePath"}, "uniqueItems": true},
        "maxAttempts": {"type": "integer", "minimum": 1, "maximum": 3},
        "acceptance": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"$ref": "#/$defs/acceptance"}}
      }
    },
    "acceptance": {
      "type": "object", "additionalProperties": false,
      "required": ["id", "argv", "workingDirectory", "expectedExitCode", "timeoutSeconds", "allowedOutputPaths"],
      "properties": {
        "id": {"type": "string", "pattern": "^check-[0-9]{3}$"},
        "argv": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
        "workingDirectory": {"$ref": "#/$defs/safeWorkspacePath"},
        "expectedExitCode": {"type": "integer", "minimum": 0, "maximum": 255},
        "timeoutSeconds": {"type": "integer", "minimum": 1, "maximum": 3600},
        "allowedOutputPaths": {"type": "array", "items": {"$ref": "#/$defs/safeWorkspacePath"}, "uniqueItems": true}
      }
    }
  }
}
