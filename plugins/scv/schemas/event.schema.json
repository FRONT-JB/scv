{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:scv:schema:event:1.0.0",
  "title": "SCV append-only task event",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "taskId", "sequence", "stateRevision", "eventId", "occurredAt", "type", "actor", "fromState", "toState", "operationId", "reasonCode", "message", "artifactRefs", "previousEventDigest"],
  "properties": {
    "schemaVersion": {"const": "1.0.0"},
    "taskId": {"type": "string", "pattern": "^T-[0-9]{8}T[0-9]{6}Z-[a-z2-7]{26}$"},
    "sequence": {"type": "integer", "minimum": 1},
    "stateRevision": {"type": "integer", "minimum": 1},
    "eventId": {"type": "string", "pattern": "^event-[0-9]{6}$"},
    "occurredAt": {"type": "string", "format": "date-time", "pattern": "^[0-9]{4}-(?:0[1-9]|1[0-2])-(?:0[1-9]|[12][0-9]|3[01])T(?:[01][0-9]|2[0-3]):[0-5][0-9]:[0-5][0-9](?:\\.[0-9]{1,9})?Z$"},
    "type": {"enum": ["TASK_CREATED", "DIALOGUE_UPDATED", "PLAN_COMPOSED", "APPROVAL_RECORDED", "APPROVAL_INVALIDATED", "STATE_TRANSITIONED", "RUN_UPDATED", "CHECKPOINT_RECORDED", "BLOCKED", "RESUMED", "ABANDONED", "HANDOFF_PREPARED"]},
    "actor": {"enum": ["kernel", "host", "backend", "user"]},
    "fromState": {"oneOf": [{"$ref": "#/$defs/stateName"}, {"type": "null"}]},
    "toState": {"oneOf": [{"$ref": "#/$defs/stateName"}, {"type": "null"}]},
    "operationId": {"type": ["string", "null"], "pattern": "^[a-z][a-z0-9]*(?:-[a-z0-9]+)*$"},
    "reasonCode": {"type": ["string", "null"], "pattern": "^[A-Z][A-Z0-9]*(?:_[A-Z0-9]+)*$"},
    "message": {"type": "string", "minLength": 1},
    "artifactRefs": {"type": "array", "items": {"$ref": "#/$defs/relativePath"}, "uniqueItems": true},
    "previousEventDigest": {"oneOf": [{"$ref": "#/$defs/digest"}, {"type": "null"}]}
  },
  "$defs": {
    "digest": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
    "relativePath": {"type": "string", "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$))(?!.*//)(?!.*\\\\)[A-Za-z0-9._-]+(?:/[A-Za-z0-9._-]+)*$"},
    "stateName": {"enum": ["PLANNING", "AWAITING_APPROVAL", "PLAN_READY", "EXECUTING", "VERIFYING", "HANDOFF_READY", "BLOCKED", "READY", "ABANDONED"]}
  }
}
