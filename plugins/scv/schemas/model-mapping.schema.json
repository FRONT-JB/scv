{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:scv:schema:model-mapping:1.0.0",
  "title": "SCV host model mapping",
  "type": "object",
  "required": ["schemaVersion", "host", "minimumHostVersion", "models"],
  "properties": {
    "schemaVersion": { "const": "1.0.0" },
    "host": { "enum": ["codex", "claude", "ollama"] },
    "minimumHostVersion": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+(?:[-+][0-9A-Za-z.-]+)?$" },
    "models": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["roleId", "modelId", "capabilityTier", "executionProfiles", "enabled"],
        "properties": {
          "roleId": { "type": "string", "pattern": "^[a-z][a-z0-9]*(?:-[a-z0-9]+)*$" },
          "modelId": { "type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/-]{0,127}$" },
          "capabilityTier": { "enum": ["sol", "terra", "luna"] },
          "executionProfiles": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": { "enum": ["dialogue", "read_only", "workspace_write", "review"] }
          },
          "enabled": { "type": "boolean" }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
