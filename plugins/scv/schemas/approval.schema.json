{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:scv:schema:approval:1.0.0",
  "title": "SCV plan approval",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "taskId", "approvalRevision", "stateRevision", "status", "scope", "approvedBy", "approvedAt", "requestRevision", "dialogueRevision", "planRevision", "requestDigest", "dialogueDigest", "planDigest", "workspaceDigest", "policyDigest", "waivers", "invalidatedAt", "invalidationReason"],
  "properties": {
    "schemaVersion": {"const": "1.0.0"},
    "taskId": {"$ref": "#/$defs/taskId"},
    "approvalRevision": {"type": "integer", "minimum": 1},
    "stateRevision": {"type": "integer", "minimum": 1},
    "status": {"enum": ["APPROVED", "INVALIDATED"]},
    "scope": {"enum": ["PLAN_ONLY", "FULL"]},
    "approvedBy": {"const": "user"},
    "approvedAt": {"$ref": "#/$defs/utcTimestamp"},
    "requestRevision": {"type": "integer", "minimum": 1},
    "dialogueRevision": {"type": "integer", "minimum": 1},
    "planRevision": {"type": "integer", "minimum": 1},
    "requestDigest": {"$ref": "#/$defs/digest"},
    "dialogueDigest": {"$ref": "#/$defs/digest"},
    "planDigest": {"$ref": "#/$defs/digest"},
    "workspaceDigest": {"$ref": "#/$defs/digest"},
    "policyDigest": {"$ref": "#/$defs/digest"},
    "waivers": {"type": "array", "items": {"$ref": "#/$defs/waiver"}},
    "invalidatedAt": {"oneOf": [{"$ref": "#/$defs/utcTimestamp"}, {"type": "null"}]},
    "invalidationReason": {"type": ["string", "null"], "minLength": 1}
  },
  "allOf": [
    {
      "if": {"properties": {"status": {"const": "APPROVED"}}, "required": ["status"]},
      "then": {"properties": {"invalidatedAt": {"type": "null"}, "invalidationReason": {"type": "null"}}},
      "else": {"properties": {"invalidatedAt": {"$ref": "#/$defs/utcTimestamp"}, "invalidationReason": {"type": "string", "minLength": 1}}}
    }
  ],
  "$defs": {
    "taskId": {"type": "string", "pattern": "^T-[0-9]{8}T[0-9]{6}Z-[a-z2-7]{26}$"},
    "digest": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
    "utcTimestamp": {"type": "string", "format": "date-time", "pattern": "^[0-9]{4}-(?:0[1-9]|1[0-2])-(?:0[1-9]|[12][0-9]|3[01])T(?:[01][0-9]|2[0-3]):[0-5][0-9]:[0-5][0-9](?:\\.[0-9]{1,9})?Z$"},
    "waiver": {
      "type": "object", "additionalProperties": false,
      "required": ["findingDigest", "impact", "reason", "mitigation", "owner", "expiresWhen", "approvalRevision"],
      "properties": {
        "findingDigest": {"$ref": "#/$defs/digest"},
        "impact": {"type": "string", "minLength": 1},
        "reason": {"type": "string", "minLength": 1},
        "mitigation": {"type": "string", "minLength": 1},
        "owner": {"type": "string", "minLength": 1},
        "expiresWhen": {"type": "string", "minLength": 1},
        "approvalRevision": {"type": "integer", "minimum": 1}
      }
    }
  }
}
