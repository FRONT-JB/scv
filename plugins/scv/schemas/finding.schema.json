{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:scv:schema:finding:1.0.0",
  "title": "SCV review finding",
  "type": "object",
  "required": ["schemaVersion", "findingId", "taskId", "source", "location", "findingClass", "severity", "summary", "evidencePaths", "action", "status", "verdict", "waiver"],
  "properties": {
    "schemaVersion": { "const": "1.0.0" },
    "findingId": { "type": "string", "pattern": "^finding-[a-z0-9][a-z0-9-]{0,63}$" },
    "taskId": { "$ref": "#/$defs/taskId" },
    "source": {
      "type": "object",
      "required": ["kind", "operationId"],
      "properties": {
        "kind": { "enum": ["deterministic_verifier", "codex_review"] },
        "operationId": { "$ref": "#/$defs/operationId" }
      },
      "additionalProperties": false
    },
    "location": {
      "type": "object",
      "required": ["path"],
      "properties": {
        "path": { "$ref": "#/$defs/portablePath" },
        "line": { "type": "integer", "minimum": 1 },
        "column": { "type": "integer", "minimum": 1 }
      },
      "additionalProperties": false
    },
    "findingClass": {
      "enum": [
        "correctness",
        "maintainability",
        "performance",
        "documentation",
        "security_boundary",
        "data_loss",
        "scope_violation",
        "sandbox_failure",
        "acceptance_failure"
      ]
    },
    "severity": { "enum": ["critical", "high", "medium", "low"] },
    "summary": { "type": "string", "minLength": 1, "maxLength": 500 },
    "evidencePaths": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/portablePath" }
    },
    "action": { "type": "string", "minLength": 1, "maxLength": 2000 },
    "status": { "enum": ["open", "resolved", "waived", "acknowledged"] },
    "verdict": { "enum": ["must_fix", "waivable", "advisory"] },
    "waiver": {
      "oneOf": [
        { "type": "null" },
        { "$ref": "#/$defs/waiver" }
      ]
    }
  },
  "allOf": [
    {
      "if": { "properties": { "status": { "const": "waived" } }, "required": ["status"] },
      "then": {
        "properties": {
          "severity": { "const": "medium" },
          "verdict": { "const": "waivable" },
          "waiver": { "$ref": "#/$defs/waiver" }
        }
      },
      "else": { "properties": { "waiver": { "type": "null" } } }
    },
    {
      "if": { "properties": { "severity": { "enum": ["critical", "high"] } }, "required": ["severity"] },
      "then": {
        "properties": {
          "verdict": { "const": "must_fix" },
          "status": { "enum": ["open", "resolved"] }
        }
      }
    },
    {
      "if": { "properties": { "severity": { "const": "medium" } }, "required": ["severity"] },
      "then": {
        "properties": {
          "verdict": { "enum": ["must_fix", "waivable"] },
          "status": { "enum": ["open", "resolved", "waived"] }
        }
      }
    },
    {
      "if": {
        "allOf": [
          {"properties": {"severity": {"const": "low"}}, "required": ["severity"]},
          {"properties": {"findingClass": {"not": {"enum": ["security_boundary", "data_loss", "scope_violation", "sandbox_failure", "acceptance_failure"]}}}, "required": ["findingClass"]}
        ]
      },
      "then": {
        "properties": {
          "verdict": { "const": "advisory" },
          "status": { "enum": ["open", "resolved", "acknowledged"] }
        }
      }
    },
    {
      "if": {
        "properties": {
          "findingClass": {
            "enum": ["security_boundary", "data_loss", "scope_violation", "sandbox_failure", "acceptance_failure"]
          }
        },
        "required": ["findingClass"]
      },
      "then": {
        "properties": {
          "verdict": { "const": "must_fix" },
          "status": { "enum": ["open", "resolved"] }
        }
      }
    },
    {
      "if": { "properties": { "status": { "const": "acknowledged" } }, "required": ["status"] },
      "then": {
        "properties": {
          "severity": { "const": "low" },
          "verdict": { "const": "advisory" }
        }
      }
    }
  ],
  "$defs": {
    "taskId": { "type": "string", "pattern": "^T-[0-9]{8}T[0-9]{6}Z-[a-z2-7]{26}$" },
    "operationId": { "type": "string", "pattern": "^[a-z][a-z0-9]*(?:-[a-z0-9]+)*$" },
    "digest": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
    "portablePath": {
      "type": "string",
      "minLength": 1,
      "maxLength": 1024,
      "pattern": "^(?!/)(?![A-Za-z]:)(?!\\.\\.(?:/|$))(?!.*(?:/)\\.\\.(?:/|$))(?!.*//)(?!.*\\\\)[A-Za-z0-9._@+-]+(?:/[A-Za-z0-9._@+-]+)*$"
    },
    "waiver": {
      "type": "object",
      "required": ["findingDigest", "impact", "reason", "mitigation", "owner", "expiresWhen", "approvalRevision"],
      "properties": {
        "findingDigest": { "$ref": "#/$defs/digest" },
        "impact": { "type": "string", "minLength": 1, "maxLength": 2000 },
        "reason": { "type": "string", "minLength": 1, "maxLength": 2000 },
        "mitigation": { "type": "string", "minLength": 1, "maxLength": 2000 },
        "owner": { "type": "string", "minLength": 1, "maxLength": 120 },
        "expiresWhen": { "type": "string", "minLength": 1, "maxLength": 500 },
        "approvalRevision": { "type": "integer", "minimum": 1 }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
