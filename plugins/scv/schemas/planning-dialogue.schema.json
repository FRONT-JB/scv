{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:scv:schema:planning-dialogue:1.0.0",
  "title": "SCV planning dialogue",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "taskId", "revision", "stage", "facts", "decisions", "assumptions", "questions", "rejectedAlternatives", "designSections", "updatedAt"],
  "properties": {
    "schemaVersion": {"const": "1.0.0"},
    "taskId": {"$ref": "#/$defs/taskId"},
    "revision": {"type": "integer", "minimum": 1},
    "stage": {"enum": ["CONTEXT", "DIALOGUE", "OPTIONS", "DESIGN_REVIEW", "PLAN_REVIEW"]},
    "facts": {"type": "array", "uniqueItems": true, "items": {"$ref": "#/$defs/fact"}},
    "decisions": {"type": "array", "uniqueItems": true, "items": {"$ref": "#/$defs/decision"}},
    "assumptions": {"type": "array", "uniqueItems": true, "items": {"$ref": "#/$defs/assumption"}},
    "questions": {"type": "array", "uniqueItems": true, "items": {"$ref": "#/$defs/question"}},
    "rejectedAlternatives": {"type": "array", "uniqueItems": true, "items": {"$ref": "#/$defs/rejectedAlternative"}},
    "designSections": {"type": "array", "uniqueItems": true, "items": {"$ref": "#/$defs/designSection"}},
    "updatedAt": {"$ref": "#/$defs/utcTimestamp"}
  },
  "$defs": {
    "taskId": {"type": "string", "pattern": "^T-[0-9]{8}T[0-9]{6}Z-[a-z2-7]{26}$"},
    "utcTimestamp": {"type": "string", "format": "date-time", "pattern": "^[0-9]{4}-(?:0[1-9]|1[0-2])-(?:0[1-9]|[12][0-9]|3[01])T(?:[01][0-9]|2[0-3]):[0-5][0-9]:[0-5][0-9](?:\\.[0-9]{1,9})?Z$"},
    "itemId": {"type": "string", "pattern": "^[a-z][a-z0-9]*(?:-[a-z0-9]+)*-[0-9]{3}$"},
    "fact": {
      "type": "object", "additionalProperties": false,
      "required": ["id", "summary", "source"],
      "properties": {"id": {"$ref": "#/$defs/itemId"}, "summary": {"type": "string", "minLength": 1}, "source": {"type": "string", "minLength": 1}}
    },
    "decision": {
      "type": "object", "additionalProperties": false,
      "required": ["id", "summary", "rationale"],
      "properties": {"id": {"$ref": "#/$defs/itemId"}, "summary": {"type": "string", "minLength": 1}, "rationale": {"type": "string", "minLength": 1}}
    },
    "assumption": {
      "type": "object", "additionalProperties": false,
      "required": ["id", "summary", "status"],
      "properties": {"id": {"$ref": "#/$defs/itemId"}, "summary": {"type": "string", "minLength": 1}, "status": {"enum": ["PROPOSED", "ACCEPTED", "REJECTED"]}}
    },
    "question": {
      "type": "object", "additionalProperties": false,
      "required": ["id", "prompt", "status", "answerSummary"],
      "properties": {"id": {"$ref": "#/$defs/itemId"}, "prompt": {"type": "string", "minLength": 1}, "status": {"enum": ["OPEN", "ANSWERED", "DEFERRED"]}, "answerSummary": {"type": ["string", "null"], "minLength": 1}},
      "allOf": [
        {
          "if": {"properties": {"status": {"const": "ANSWERED"}}, "required": ["status"]},
          "then": {"properties": {"answerSummary": {"type": "string", "minLength": 1}}}
        },
        {
          "if": {"properties": {"status": {"const": "OPEN"}}, "required": ["status"]},
          "then": {"properties": {"answerSummary": {"type": "null"}}}
        }
      ]
    },
    "rejectedAlternative": {
      "type": "object", "additionalProperties": false,
      "required": ["id", "summary", "reason"],
      "properties": {"id": {"$ref": "#/$defs/itemId"}, "summary": {"type": "string", "minLength": 1}, "reason": {"type": "string", "minLength": 1}}
    },
    "designSection": {
      "type": "object", "additionalProperties": false,
      "required": ["id", "title", "summary", "status"],
      "properties": {"id": {"$ref": "#/$defs/itemId"}, "title": {"type": "string", "minLength": 1}, "summary": {"type": "string", "minLength": 1}, "status": {"enum": ["PENDING", "CONFIRMED", "CHANGES_REQUESTED"]}}
    }
  }
}
