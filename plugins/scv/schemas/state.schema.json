{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:scv:schema:state:1.0.0",
  "title": "SCV task state",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "taskId", "revision", "state", "planningStage", "binding", "checkpoint", "blocker", "lastEventSequence", "createdAt", "updatedAt"],
  "properties": {
    "schemaVersion": {"const": "1.0.0"},
    "taskId": {"$ref": "#/$defs/taskId"},
    "revision": {"type": "integer", "minimum": 1},
    "state": {"$ref": "#/$defs/stateName"},
    "planningStage": {"oneOf": [{"$ref": "#/$defs/planningStage"}, {"type": "null"}]},
    "binding": {"$ref": "#/$defs/binding"},
    "checkpoint": {"oneOf": [{"$ref": "#/$defs/checkpoint"}, {"type": "null"}]},
    "blocker": {"oneOf": [{"$ref": "#/$defs/blocker"}, {"type": "null"}]},
    "lastEventSequence": {"type": "integer", "minimum": 0},
    "createdAt": {"$ref": "#/$defs/utcTimestamp"},
    "updatedAt": {"$ref": "#/$defs/utcTimestamp"}
  },
  "allOf": [
    {
      "if": {"properties": {"state": {"const": "PLANNING"}}, "required": ["state"]},
      "then": {"properties": {"planningStage": {"$ref": "#/$defs/planningStage"}}},
      "else": {"properties": {"planningStage": {"type": "null"}}}
    },
    {
      "if": {"properties": {"state": {"const": "BLOCKED"}}, "required": ["state"]},
      "then": {"properties": {"blocker": {"$ref": "#/$defs/blocker"}}},
      "else": {"properties": {"blocker": {"type": "null"}}}
    }
  ],
  "$defs": {
    "taskId": {"type": "string", "pattern": "^T-[0-9]{8}T[0-9]{6}Z-[a-z2-7]{26}$"},
    "digest": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
    "utcTimestamp": {
      "type": "string",
      "format": "date-time",
      "pattern": "^[0-9]{4}-(?:0[1-9]|1[0-2])-(?:0[1-9]|[12][0-9]|3[01])T(?:[01][0-9]|2[0-3]):[0-5][0-9]:[0-5][0-9](?:\\.[0-9]{1,9})?Z$"
    },
    "absolutePath": {"type": "string", "pattern": "^/", "not": {"pattern": "(?:^|/)\\.\\.(?:/|$)|//|\\\\"}},
    "stateName": {"enum": ["PLANNING", "AWAITING_APPROVAL", "PLAN_READY", "EXECUTING", "VERIFYING", "HANDOFF_READY", "BLOCKED", "READY", "ABANDONED"]},
    "resumableState": {"enum": ["PLANNING", "AWAITING_APPROVAL", "PLAN_READY", "EXECUTING", "VERIFYING", "HANDOFF_READY"]},
    "planningStage": {"enum": ["CONTEXT", "DIALOGUE", "OPTIONS", "DESIGN_REVIEW", "PLAN_REVIEW"]},
    "binding": {
      "type": "object",
      "additionalProperties": false,
      "required": ["repositoryId", "gitCommonDirDigest", "projectRoot", "worktreeRoot", "branch"],
      "properties": {
        "repositoryId": {
          "type": "string",
          "format": "uuid",
          "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-4[0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$"
        },
        "gitCommonDirDigest": {"$ref": "#/$defs/digest"},
        "projectRoot": {"$ref": "#/$defs/absolutePath"},
        "worktreeRoot": {"$ref": "#/$defs/absolutePath"},
        "branch": {"type": "string", "minLength": 1, "maxLength": 255, "pattern": "^[^\\u0000-\\u001f~^:?*\\[]+$"}
      }
    },
    "checkpoint": {
      "type": "object",
      "additionalProperties": false,
      "required": ["head", "indexDigest", "contentDigest", "planDigest", "policyDigest", "operationId", "stateRevision", "verifiedAt"],
      "properties": {
        "head": {"type": "string", "pattern": "^(?:[a-f0-9]{40}|[a-f0-9]{64})$"},
        "indexDigest": {"$ref": "#/$defs/digest"},
        "contentDigest": {"$ref": "#/$defs/digest"},
        "planDigest": {"oneOf": [{"$ref": "#/$defs/digest"}, {"type": "null"}]},
        "policyDigest": {"$ref": "#/$defs/digest"},
        "operationId": {"type": "string", "pattern": "^[a-z][a-z0-9]*(?:-[a-z0-9]+)*$"},
        "stateRevision": {"type": "integer", "minimum": 1},
        "verifiedAt": {"$ref": "#/$defs/utcTimestamp"}
      }
    },
    "blocker": {
      "type": "object",
      "additionalProperties": false,
      "required": ["blockedFrom", "reasonCode", "resumeTo", "details", "userAction", "verificationPredicates", "blockedAt"],
      "properties": {
        "blockedFrom": {"$ref": "#/$defs/resumableState"},
        "reasonCode": {"enum": ["BACKEND_UNAVAILABLE", "HOST_INCOMPATIBLE", "SANDBOX_UNAVAILABLE", "POLICY_DENIED", "CREDENTIAL_UNAVAILABLE", "WORKSPACE_DRIFT", "BINDING_MISMATCH", "EVIDENCE_CORRUPT", "STATE_CORRUPT"]},
        "resumeTo": {"$ref": "#/$defs/resumableState"},
        "details": {"type": "string", "minLength": 1},
        "userAction": {"type": "string", "minLength": 1},
        "verificationPredicates": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
        "blockedAt": {"$ref": "#/$defs/utcTimestamp"}
      },
      "allOf": [
        {
          "if": {
            "properties": {"reasonCode": {"const": "WORKSPACE_DRIFT"}},
            "required": ["reasonCode"]
          },
          "then": {
            "anyOf": [
              {"$ref": "#/$defs/sameStateResume"},
              {
                "properties": {"resumeTo": {"const": "PLANNING"}},
                "required": ["resumeTo"]
              }
            ]
          },
          "else": {"$ref": "#/$defs/sameStateResume"}
        }
      ]
    },
    "sameStateResume": {
      "oneOf": [
        {
          "properties": {
            "blockedFrom": {"const": "PLANNING"},
            "resumeTo": {"const": "PLANNING"}
          },
          "required": ["blockedFrom", "resumeTo"]
        },
        {
          "properties": {
            "blockedFrom": {"const": "AWAITING_APPROVAL"},
            "resumeTo": {"const": "AWAITING_APPROVAL"}
          },
          "required": ["blockedFrom", "resumeTo"]
        },
        {
          "properties": {
            "blockedFrom": {"const": "PLAN_READY"},
            "resumeTo": {"const": "PLAN_READY"}
          },
          "required": ["blockedFrom", "resumeTo"]
        },
        {
          "properties": {
            "blockedFrom": {"const": "EXECUTING"},
            "resumeTo": {"const": "EXECUTING"}
          },
          "required": ["blockedFrom", "resumeTo"]
        },
        {
          "properties": {
            "blockedFrom": {"const": "VERIFYING"},
            "resumeTo": {"const": "VERIFYING"}
          },
          "required": ["blockedFrom", "resumeTo"]
        },
        {
          "properties": {
            "blockedFrom": {"const": "HANDOFF_READY"},
            "resumeTo": {"const": "HANDOFF_READY"}
          },
          "required": ["blockedFrom", "resumeTo"]
        }
      ]
    }
  }
}
