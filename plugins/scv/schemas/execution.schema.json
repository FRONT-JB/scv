{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:scv:schema:execution:1.0.0",
  "title": "SCV execution record",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "taskId", "revision", "planRevision", "currentRunId", "runs", "updatedAt"],
  "properties": {
    "schemaVersion": {"const": "1.0.0"},
    "taskId": {"$ref": "#/$defs/taskId"},
    "revision": {"type": "integer", "minimum": 1},
    "planRevision": {"type": "integer", "minimum": 1},
    "currentRunId": {"oneOf": [{"$ref": "#/$defs/runId"}, {"type": "null"}]},
    "runs": {"type": "array", "uniqueItems": true, "items": {"$ref": "#/$defs/run"}},
    "updatedAt": {"$ref": "#/$defs/utcTimestamp"}
  },
  "$defs": {
    "taskId": {"type": "string", "pattern": "^T-[0-9]{8}T[0-9]{6}Z-[a-z2-7]{26}$"},
    "runId": {"type": "string", "pattern": "^run-[0-9]{3}$"},
    "stepId": {"type": "string", "pattern": "^step-[0-9]{3}$"},
    "digest": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
    "utcTimestamp": {"type": "string", "format": "date-time", "pattern": "^[0-9]{4}-(?:0[1-9]|1[0-2])-(?:0[1-9]|[12][0-9]|3[01])T(?:[01][0-9]|2[0-3]):[0-5][0-9]:[0-5][0-9](?:\\.[0-9]{1,9})?Z$"},
    "relativePath": {"type": "string", "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$))(?!.*//)(?!.*\\\\)[A-Za-z0-9._-]+(?:/[A-Za-z0-9._-]+)*$"},
    "run": {
      "type": "object", "additionalProperties": false,
      "required": ["id", "status", "startedAt", "finishedAt", "terminationReason", "currentStepId", "steps"],
      "properties": {
        "id": {"$ref": "#/$defs/runId"},
        "status": {"enum": ["RUNNING", "SUCCEEDED", "FAILED", "BLOCKED", "CANCELLED"]},
        "startedAt": {"$ref": "#/$defs/utcTimestamp"},
        "finishedAt": {"oneOf": [{"$ref": "#/$defs/utcTimestamp"}, {"type": "null"}]},
        "terminationReason": {"enum": [null, "COMPLETED", "BUDGET_EXHAUSTED", "STALLED", "OSCILLATING", "VERIFIER_DISAGREEMENT", "BLOCKED", "CANCELLED"]},
        "currentStepId": {"oneOf": [{"$ref": "#/$defs/stepId"}, {"type": "null"}]},
        "steps": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"$ref": "#/$defs/stepRun"}}
      },
      "allOf": [
        {
          "if": {"properties": {"status": {"const": "RUNNING"}}, "required": ["status"]},
          "then": {"properties": {"finishedAt": {"type": "null"}, "terminationReason": {"type": "null"}, "currentStepId": {"$ref": "#/$defs/stepId"}}}
        },
        {
          "if": {"properties": {"status": {"const": "SUCCEEDED"}}, "required": ["status"]},
          "then": {"properties": {"finishedAt": {"$ref": "#/$defs/utcTimestamp"}, "terminationReason": {"const": "COMPLETED"}, "currentStepId": {"type": "null"}, "steps": {"items": {"allOf": [{"$ref": "#/$defs/stepRun"}, {"properties": {"status": {"enum": ["SUCCEEDED", "SKIPPED"]}}}]}}}}
        },
        {
          "if": {"properties": {"status": {"const": "FAILED"}}, "required": ["status"]},
          "then": {"properties": {"finishedAt": {"$ref": "#/$defs/utcTimestamp"}, "terminationReason": {"enum": ["BUDGET_EXHAUSTED", "STALLED", "OSCILLATING", "VERIFIER_DISAGREEMENT"]}, "currentStepId": {"type": "null"}}}
        },
        {
          "if": {"properties": {"status": {"const": "BLOCKED"}}, "required": ["status"]},
          "then": {"properties": {"finishedAt": {"$ref": "#/$defs/utcTimestamp"}, "terminationReason": {"const": "BLOCKED"}}}
        },
        {
          "if": {"properties": {"status": {"const": "CANCELLED"}}, "required": ["status"]},
          "then": {"properties": {"finishedAt": {"$ref": "#/$defs/utcTimestamp"}, "terminationReason": {"const": "CANCELLED"}, "currentStepId": {"type": "null"}}}
        }
      ]
    },
    "stepRun": {
      "type": "object", "additionalProperties": false,
      "required": ["stepId", "status", "attempts"],
      "properties": {
        "stepId": {"$ref": "#/$defs/stepId"},
        "status": {"enum": ["PENDING", "RUNNING", "SUCCEEDED", "FAILED", "SKIPPED"]},
        "attempts": {
          "type": "array",
          "maxItems": 3,
          "uniqueItems": true,
          "prefixItems": [
            {"allOf": [{"$ref": "#/$defs/attempt"}, {"properties": {"number": {"const": 1}}}]},
            {"allOf": [{"$ref": "#/$defs/attempt"}, {"properties": {"number": {"const": 2}}}]},
            {"allOf": [{"$ref": "#/$defs/attempt"}, {"properties": {"number": {"const": 3}}}]}
          ],
          "items": false
        }
      },
      "allOf": [
        {
          "if": {"properties": {"status": {"const": "PENDING"}}, "required": ["status"]},
          "then": {"properties": {"attempts": {"maxItems": 0}}}
        },
        {
          "if": {"properties": {"status": {"enum": ["RUNNING", "SUCCEEDED", "FAILED"]}}, "required": ["status"]},
          "then": {"properties": {"attempts": {"minItems": 1}}}
        },
        {
          "if": {"properties": {"status": {"const": "SKIPPED"}}, "required": ["status"]},
          "then": {"properties": {"attempts": {"maxItems": 0}}}
        }
      ]
    },
    "attempt": {
      "type": "object", "additionalProperties": false,
      "required": ["number", "status", "operationId", "backendProfile", "startedAt", "finishedAt", "evidenceRefs", "failureSignature", "acceptanceVector", "workspaceFingerprint"],
      "properties": {
        "number": {"type": "integer", "minimum": 1, "maximum": 3},
        "status": {"enum": ["RUNNING", "SUCCEEDED", "FAILED", "INTERRUPTED"]},
        "operationId": {"type": "string", "pattern": "^[a-z][a-z0-9]*(?:-[a-z0-9]+)*$"},
        "backendProfile": {"type": "string", "pattern": "^[a-z][a-z0-9]*(?:-[a-z0-9]+)*$"},
        "startedAt": {"$ref": "#/$defs/utcTimestamp"},
        "finishedAt": {"oneOf": [{"$ref": "#/$defs/utcTimestamp"}, {"type": "null"}]},
        "evidenceRefs": {"type": "array", "items": {"$ref": "#/$defs/relativePath"}, "uniqueItems": true},
        "failureSignature": {"oneOf": [{"$ref": "#/$defs/digest"}, {"type": "null"}]},
        "acceptanceVector": {"type": "array", "uniqueItems": true, "items": {"$ref": "#/$defs/checkResult"}},
        "workspaceFingerprint": {"oneOf": [{"$ref": "#/$defs/digest"}, {"type": "null"}]}
      },
      "allOf": [
        {
          "if": {"properties": {"status": {"const": "RUNNING"}}, "required": ["status"]},
          "then": {"properties": {"finishedAt": {"type": "null"}, "failureSignature": {"type": "null"}}}
        },
        {
          "if": {"properties": {"status": {"const": "SUCCEEDED"}}, "required": ["status"]},
          "then": {"properties": {"finishedAt": {"$ref": "#/$defs/utcTimestamp"}, "failureSignature": {"type": "null"}}}
        },
        {
          "if": {"properties": {"status": {"const": "FAILED"}}, "required": ["status"]},
          "then": {"properties": {"finishedAt": {"$ref": "#/$defs/utcTimestamp"}, "failureSignature": {"$ref": "#/$defs/digest"}}}
        },
        {
          "if": {"properties": {"status": {"const": "INTERRUPTED"}}, "required": ["status"]},
          "then": {"properties": {"finishedAt": {"$ref": "#/$defs/utcTimestamp"}}}
        }
      ]
    },
    "checkResult": {
      "type": "object", "additionalProperties": false,
      "required": ["checkId", "passed", "evidenceRef"],
      "properties": {"checkId": {"type": "string", "pattern": "^check-[0-9]{3}$"}, "passed": {"type": "boolean"}, "evidenceRef": {"$ref": "#/$defs/relativePath"}}
    }
  }
}
