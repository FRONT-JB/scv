{
  "schemaVersion": "1.0.0",
  "transitions": {
    "PLANNING": ["AWAITING_APPROVAL", "BLOCKED", "ABANDONED"],
    "AWAITING_APPROVAL": ["PLANNING", "PLAN_READY", "BLOCKED", "ABANDONED"],
    "PLAN_READY": ["EXECUTING", "PLANNING", "BLOCKED", "ABANDONED"],
    "EXECUTING": ["VERIFYING", "PLANNING", "BLOCKED", "ABANDONED"],
    "VERIFYING": ["EXECUTING", "PLANNING", "HANDOFF_READY", "BLOCKED", "ABANDONED"],
    "HANDOFF_READY": ["EXECUTING", "PLANNING", "READY", "BLOCKED", "ABANDONED"],
    "BLOCKED": ["PLANNING", "AWAITING_APPROVAL", "PLAN_READY", "EXECUTING", "VERIFYING", "HANDOFF_READY", "ABANDONED"],
    "READY": [],
    "ABANDONED": []
  },
  "blockedResume": {
    "sameStateReasons": ["BACKEND_UNAVAILABLE", "HOST_INCOMPATIBLE", "SANDBOX_UNAVAILABLE", "POLICY_DENIED", "CREDENTIAL_UNAVAILABLE", "BINDING_MISMATCH", "EVIDENCE_CORRUPT", "STATE_CORRUPT"],
    "sameStateResumeTo": "blockedFrom",
    "workspaceDrift": {
      "reasonCode": "WORKSPACE_DRIFT",
      "exactRestoreResumeTo": "blockedFrom",
      "rebaselineResumeTo": "PLANNING"
    },
    "abandon": {
      "targetState": "ABANDONED",
      "requiresUserConfirmation": true,
      "usesResumeTo": false
    }
  },
  "planning": {
    "stages": ["CONTEXT", "DIALOGUE", "OPTIONS", "DESIGN_REVIEW", "PLAN_REVIEW"],
    "requireExplicitAssumptionAcceptance": true
  },
  "attempts": {
    "minimum": 1,
    "default": 2,
    "maximum": 3,
    "terminationReasons": ["budget_exhausted", "stalled", "oscillating", "verifier_disagreement"]
  },
  "findings": {
    "severityDisposition": {
      "critical": "must_fix",
      "high": "must_fix",
      "medium": "must_fix",
      "low": "advisory"
    },
    "nonWaivableClasses": ["security_boundary", "data_loss", "scope_violation", "sandbox_failure", "acceptance_failure"]
  },
  "executors": {
    "allowed": ["host", "kernel", "backend"],
    "reviewBackend": "codex"
  },
  "retention": {
    "automaticDeletion": false,
    "terminalTaskDaysBeforePrune": 90,
    "runtimeCleanupDays": 7
  }
}
